{
  "schemaVersion": 1,
  "id": "signplate",
  "version": "${version}",
  "name": "SignPlate",
  "description": "Sign Templates for Fabric",
  "authors": [
    "TheDemonPrince"
  ],
  "contact": {
    "homepage": "https://github.com/TDPMC/SignPlate",
    "issues": "https://github.com/TDPMC/SignPlate/issues"
  },
  "license": "MIT",
  "icon": "assets/signplate/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "dk.thedemonprince.client.SignplateClient"
    ],
    "main": [
      "dk.thedemonprince.Signplate"
    ],
    "modmenu": [
      "dk.thedemonprince.client.integration.ModMenuIntegration"
    ]
  },
  "mixins": [
    "signplate.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ">=1.20.6 <=1.21.1"
